# ═══════════════════════════════════════════════════════════════════════════
#  Shorts Factory — CONFIG TEMPLATE.  ⚠ THIS FILE CONTAINS NO REAL SECRETS. ⚠
#  Every value below is a fake PLACEHOLDER (the <ANGLE_BRACKETS> mark the spots
#  you replace). Copy this file to `.env` (which is git-ignored) and put YOUR
#  real values there — never in this file, never in git.
# ═══════════════════════════════════════════════════════════════════════════

# ── YouTube (via Postiz) ─────────────────────────────────────
# In this project these come from the Postiz Docker container env + Postgres.
# If you run standalone, set them here instead and adapt the scripts.
YOUTUBE_CLIENT_ID=<YOUR_GOOGLE_OAUTH_CLIENT_ID>.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=<PASTE_YOUR_GOOGLE_OAUTH_CLIENT_SECRET_HERE>
# The long-lived refresh token with the youtube.upload scope (kept in Postiz's DB by default):
YOUTUBE_REFRESH_TOKEN=<PASTE_YOUR_YOUTUBE_REFRESH_TOKEN_HERE>

# ── GCP project (for the YouTube Analytics API) ──────────────
GCP_PROJECT_NUMBER=<YOUR_GCP_PROJECT_NUMBER>

# ── Postiz (self-hosted) ─────────────────────────────────────
POSTIZ_BASE_URL=http://localhost:4007/api
# Get from Postiz UI → Settings → Developers → Access. Also readable from ~/.config/postiz/key
POSTIZ_API_KEY=<PASTE_YOUR_POSTIZ_ORG_API_KEY_HERE>

# ── Gmail notifications (digest + failure alerts) ────────────
# Create at https://myaccount.google.com/apppasswords  (needs 2-Step Verification).
# Stored by the app at ~/.config/shorts/email.json (mode 600) — do not paste real values into git.
NOTIFY_EMAIL_ADDRESS=<your-email@gmail.com>
NOTIFY_EMAIL_APP_PASSWORD=<PASTE_YOUR_16_CHAR_GMAIL_APP_PASSWORD_HERE>
