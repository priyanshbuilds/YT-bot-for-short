# ═══════════════════════════════════════════════════════════════════════════
#  ClipPilot secrets — CONFIG TEMPLATE.  ⚠ NO REAL KEYS IN THIS FILE. ⚠
#  Every value is a fake <PLACEHOLDER>. Copy to ".env" (which is gitignored) and
#  put YOUR real values there. Never commit a real .env or paste keys into chat.
# ═══════════════════════════════════════════════════════════════════════════

# Required for the live Claude brain (the video-understanding vision pass).
# Get one at https://console.anthropic.com/ . Without it, understand_video runs
# deterministic-only (scenes + keyframes, no semantic read).
ANTHROPIC_API_KEY=<PASTE_YOUR_ANTHROPIC_API_KEY_HERE>   # real keys start "sk-ant-"; this is just a placeholder

# Optional: override the brain model (default is the most capable, claude-opus-4-8).
# For cheaper bulk vision use claude-sonnet-4-6.  ($5/$25 vs $3/$15 per 1M tokens)
# CLIPPILOT_BRAIN_MODEL=claude-sonnet-4-6

# ── Publishing (optional — without any, ClipPilot exports metadata for manual upload) ──

# FREE first-party YouTube Data API v3 (preferred). Create an OAuth client in
# Google Cloud Console (Desktop app), enable the YouTube Data API, then run the
# one-time consent flow to get a refresh token (see docs/09 §7).
# YOUTUBE_CLIENT_ID=...apps.googleusercontent.com
# YOUTUBE_CLIENT_SECRET=...
# YOUTUBE_REFRESH_TOKEN=...

# PAID cross-poster (YouTube + IG/FB + TikTok in one POST) via upload-post.com.
# UPLOAD_POST_API_KEY=...
# UPLOAD_POST_USERNAME=...

# FREE first-party Instagram/Facebook Reels (Meta Graph API). NOTE: the Graph API
# fetches the video from a PUBLIC URL — you must host the clip yourself (S3/CDN/etc).
# Needs an IG Business/Creator account + a long-lived token.
# INSTAGRAM_USER_ID=...
# INSTAGRAM_ACCESS_TOKEN=...

# Optional, FREE: a Pexels API key upgrades Section B b-roll to curated, high-res
# stock photos + portrait video (https://www.pexels.com/api/). Without it, b-roll
# falls back to free Bing image search (lower quality).
# PEXELS_API_KEY=...

# Optional, FREE: a Pixabay API key (https://pixabay.com/api/docs/) enables real
# motion-footage montages (the anti-slop visual) as an alternative free video source
# alongside Pexels. With either key set, Section B prefers a real-clip montage over
# Ken-Burns stills. Without either, it uses stills.
# PIXABAY_API_KEY=...

# Optional, PAID: a hosted text-to-image API to GENERATE cinematic Section-B stills
# (the honest CPU-only stand-in for the GPU gen models). Vendor-neutral — any
# OpenAI-images-compatible endpoint. Without it, b-roll uses stock/free sources.
# GEN_IMAGE_API_KEY=...
# GEN_IMAGE_ENDPOINT=https://api.openai.com/v1/images/generations
# GEN_IMAGE_MODEL=gpt-image-1
# GEN_IMAGE_SIZE=1024x1536

# Optional, PAID: hosted TEXT-TO-VIDEO + TTS/MUSIC for the timeline editor (palmier
# generateVideo/generateAudio parity). Vendor-neutral — any endpoint returning a video/
# audio URL (or raw audio bytes). Without keys the editor uses your own/stock media.
# GEN_VIDEO_API_KEY=...
# GEN_VIDEO_ENDPOINT=https://api.openai.com/v1/videos/generations
# GEN_VIDEO_MODEL=sora-2
# GEN_AUDIO_API_KEY=...
# GEN_AUDIO_ENDPOINT=https://api.elevenlabs.io/v1/text-to-speech
# GEN_AUDIO_VOICE=...
