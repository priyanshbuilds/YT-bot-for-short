# Normalize line endings across platforms
* text=auto eol=lf

# Windows-only runners keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Shell scripts must stay LF
*.sh text eol=lf

# Treat these as binary (never diff/merge)
*.mp4 binary
*.wav binary
*.png binary
*.jpg binary
*.webp binary
*.wav binary
*.xlsx binary
